    {
      "id": "GVhWFmMTDOgTvEFySKaIB",
      "type": "text",
      "x": 838.9500122070312,
      "y": 192.12503356933593,
      "width": 759.375,
      "height": 307.2,
      "angle": 0,
      "strokeColor": "#000000",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,

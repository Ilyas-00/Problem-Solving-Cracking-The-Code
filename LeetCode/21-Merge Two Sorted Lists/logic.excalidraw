      "updated": 1774000744726,
      "link": null,
      "locked": false,
      "text": "node = ListNode(0)\ncurrent = node\n\npointer variables (current,\n                   list1,\n                   list2)\n\ncurrent.next = list1     => existing node\n\n\n    Space Complexity: O(1)",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "node = ListNode(0)\ncurrent = node\n\npointer variables (current,\n                   list1,\n                   list2)\n\ncurrent.next = list1     => existing node\n\n\n    Space Complexity: O(1)"
    },

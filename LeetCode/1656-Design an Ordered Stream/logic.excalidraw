      "link": null,
      "locked": false,
      "text": "self.stream = [None] * (n + 1)                          => O(n)\n\n\nself.stream[idKey] = value                              => O(1)\n\n\nwhile self.ptr <= self.n and self.stream[self.ptr] :    => O(n)\n\n        \n                O(n)",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "self.stream = [None] * (n + 1)                          => O(n)\n\n\nself.stream[idKey] = value                              => O(1)\n\n\nwhile self.ptr <= self.n and self.stream[self.ptr] :    => O(n)\n\n        \n                O(n)"
    },
    {
      "id": "NXjfS4pdyEdG6fWoEJOhX",

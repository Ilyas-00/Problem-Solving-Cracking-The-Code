      "boundElements": null,
      "updated": 1773746821992,
      "link": null,
      "locked": false,
      "text": "self.stream = [None] * (n + 1)         => array of size n+1\n\nself.ptr                               => an integer                                 => O(1)\n\nresult                                 => temporary list to store the consecutive \n                                          inserted elements: at most n elements      => O(n)",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "self.stream = [None] * (n + 1)         => array of size n+1\n\nself.ptr                               => an integer                                 => O(1)\n\nresult                                 => temporary list to store the consecutive \n                                          inserted elements: at most n elements      => O(n)"
    },

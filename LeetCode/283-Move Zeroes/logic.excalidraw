      "boundElements": null,
      "updated": 1773495427339,
      "link": null,
      "locked": false,
      "text": "Variables used:\n\ni → pointer for non-zero elements\n\nj → index for the first loop\n\nk → index for the second loop\n\nNo additional array is created → in-place\n\n       O(1)",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Variables used:\n\ni → pointer for non-zero elements\n\nj → index for the first loop\n\nk → index for the second loop\n\nNo additional array is created → in-place\n\n       O(1)",
      "autoResize": true,
      "lineHeight": 1.25
    },
